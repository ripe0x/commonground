# Alchemy RPC endpoints (get a free key at https://alchemy.com)
NEXT_PUBLIC_ALCHEMY_MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ALCHEMY_BASE_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_API_KEY=YOUR_KEY

# WalletConnect project ID (get one free at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# Ponder indexer URL (default: local dev server)
# For production, use: https://commonground-indexer.fly.dev
PONDER_URL=http://localhost:42069
NEXT_PUBLIC_PONDER_URL=http://localhost:42069

# Site URL (for metadata/OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
